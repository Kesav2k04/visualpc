# =====================================================
# VisualPC — Environment Variables Template
# Copy to .env (root) or backend/.env and fill in values
# =====================================================

# ----- PostgreSQL (REQUIRED) -----
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/visualpc_monitor

# ----- JWT / Secret Keys -----
VISUALPC_SECRET_KEY=your-secret-key-change-me
FASTAPI_SECRET_KEY=your-secret-key-change-me

# ----- Admin Bootstrap -----
# Default admin account password (used for first login and DB seed)
# IMPORTANT: Change this in production!
ADMIN_BOOTSTRAP_PASSWORD=visualpc2026

# ----- CORS -----
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Master Scheduler -----
MASTER_NODE_URL=http://localhost:9000

# ----- GPU Worker -----
# Set this to your actual GPU worker Tailscale/network IP
GPU_WORKER_URL=http://localhost:7000/execute-job
GPU_WORKER_PORT=7000
MONITOR_API_URL=http://localhost:8500

# ----- NextAuth (frontend) -----
NEXTAUTH_SECRET=your-nextauth-secret-change-me
NEXTAUTH_URL=http://localhost:3000

# ----- OAuth Providers (optional) -----
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# ----- Frontend API -----
NEXT_PUBLIC_API_BASE=http://localhost:8500
